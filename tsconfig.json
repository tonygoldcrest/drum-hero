{
  "compilerOptions": {
    "target": "es2022",
    "module": "ESNext",
    "lib": ["dom", "es2022"],
    "jsx": "react-jsx",
    "strict": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "skipLibCheck": true,
    "outDir": "out",
    "rootDir": "src"
  },
  "include": ["src", "assets/assets.d.ts"],
  "exclude": ["test", "release/build", "out", ".erb/dll"]
}
