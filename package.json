{
  "name": "sight-kick",
  "description": "Play your favorite Clone Hero drum tracks",
  "version": "0.1.0",
  "keywords": [
    "clonehero",
    "drums",
    "sheetmusic",
    "guitarhero",
    "rockband"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tonygoldcrest/sightkick.git"
  },
  "license": "MIT",
  "author": {
    "name": "Anton Korolkov",
    "email": "peancored@gmail.com"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "build": "electron-vite build",
    "postinstall": "node scripts/postinstall.js",
    "lint": "cross-env NODE_ENV=development eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "package": "yarn build && electron-builder build --mac --publish never",
    "package:win": "yarn build && electron-builder build -w --x64 --publish never",
    "rebuild": "electron-rebuild --parallel --types prod,dev,optional",
    "start": "electron-vite dev",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest"
  },
  "browserslist": [],
  "prettier": {
    "singleQuote": true,
    "overrides": [
      {
        "files": [
          ".prettierrc",
          ".eslintrc"
        ],
        "options": {
          "parser": "json"
        }
      }
    ]
  },
  "jest": {
    "roots": [
      "<rootDir>/src"
    ],
    "moduleDirectories": [
      "node_modules",
      "src"
    ],
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/src/__mocks__/fileMock.js",
      "\\.(css|less|sass|scss)$": "identity-obj-proxy"
    },
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost/"
    },
    "testPathIgnorePatterns": [
      "release/app/dist",
      "out"
    ],
    "transform": {
      "\\.(ts|tsx|js|jsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "CommonJS"
          }
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(antd|@ant-design|rc-[^/]+|@rc-component|@fortawesome|@babel/runtime)/)"
    ]
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@eliwhite/parse-sng": "^4.0.3-eliwhite.0",
    "@fortawesome/fontawesome-svg-core": "^6.5.1",
    "@fortawesome/free-regular-svg-icons": "^6.5.1",
    "@fortawesome/free-solid-svg-icons": "^6.5.1",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@julusian/midi": "^3.6.1",
    "@tanstack/react-virtual": "^3.0.2",
    "@tonejs/midi": "^2.0.28",
    "antd": "^6.4.4",
    "clsx": "^2.1.1",
    "electron-debug": "^3.2.0",
    "electron-log": "^4.4.8",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.4",
    "es-toolkit": "^1.47.1",
    "fuse.js": "^7.0.0",
    "ini": "^4.1.1",
    "lodash": "^4.17.21",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.16.0",
    "scan-chart": "^8.0.1",
    "tailwind-merge": "^3.6.0",
    "use-debounce": "^10.0.0",
    "vexflow": "^4.2.3"
  },
  "devDependencies": {
    "@electron/notarize": "^2.1.0",
    "@electron/rebuild": "^4.0.4",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^16.0.0",
    "@types/glob": "^8.1.0",
    "@types/ini": "^4.1.0",
    "@types/jest": "^29.5.5",
    "@types/node": "20.6.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-test-renderer": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^7.0.3",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.4",
    "electron-devtools-installer": "^4.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^8.49.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-erb": "^4.1.0-0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-compat": "^4.2.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jest": "^27.4.0",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.0.3",
    "react-test-renderer": "^19.0.0",
    "sass": "^1.67.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "vite": "^5.4.21"
  },
  "build": {
    "productName": "SightKick",
    "buildVersion": "0.1.0",
    "appId": "org.sk.SightKick",
    "asar": true,
    "asarUnpack": "**\\*.{node,dll}",
    "files": [
      "out/**",
      "node_modules/**",
      "package.json"
    ],
    "afterSign": "scripts/notarize.js",
    "mac": {
      "target": {
        "target": "default",
        "arch": [
          "arm64",
          "x64"
        ]
      },
      "type": "distribution",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "directories": {
      "buildResources": "assets",
      "output": "release/build"
    },
    "extraResources": [
      "./assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "tonygoldcrest",
      "repo": "sightkick"
    }
  },
  "engines": {
    "node": ">=14.x",
    "npm": ">=7.x"
  },
  "packageManager": "yarn@4.17.0"
}
